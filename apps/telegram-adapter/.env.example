# Telegram bot API token (from @BotFather)
TALOS_TELEGRAM_BOT_TOKEN=change-me-to-your-bot-token

# Comma-separated chat IDs allowed to trigger runs; anything else is rejected and audited
TALOS_TELEGRAM_ALLOWED_CHAT_IDS=change-me-to-a-comma-separated-list-of-chat-ids

# Internal API root
TALOS_API_BASE_URL=http://talos-api:8080

# Seeded chat trigger service account (must match talos-api's TALOS_TELEGRAM_SERVICE_EMAIL/PASSWORD)
TALOS_TELEGRAM_SERVICE_EMAIL=telegram-bot@talos.local
TALOS_TELEGRAM_SERVICE_PASSWORD=change-me

# Deep links back into the dashboard (e.g. "view the run")
TALOS_WEB_BASE_URL=http://localhost:4200

# Transport + locks
TALOS_RABBITMQ_URL=amqp://talos:talos@rabbitmq:5672
TALOS_REDIS_URL=redis://redis:6379

# Long-poll timeout, seconds
TALOS_TELEGRAM_POLL_TIMEOUT_SECONDS=30
