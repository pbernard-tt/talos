# Workspace volume
TALOS_WORKSPACES_ROOT=/var/talos/workspaces

# Credential isolation volume
TALOS_PROVIDER_HOMES_ROOT=/var/talos/provider-homes

# Auth for artifact/log posts to talos-api (same value as talos-api's TALOS_INTERNAL_API_TOKEN)
TALOS_INTERNAL_API_TOKEN=change-me-to-a-random-64-char-token

# Retention, days
TALOS_MAX_WORKSPACE_AGE_DAYS=7

# Phase 11: per-run Docker container execution (Section 8)
TALOS_RUN_WORKSPACES_VOLUME=talos_workspaces
TALOS_RUN_PROVIDER_HOMES_VOLUME=talos_provider_homes
TALOS_RUN_NETWORK=talos_run_network
TALOS_RUN_MEMORY_LIMIT=1g
TALOS_RUN_CPU_LIMIT=1
TALOS_RUN_PIDS_LIMIT=256

# Not read by the app -- consumed by infra/*.yml's group_add so the container's non-root `talos`
# user can use the mounted /var/run/docker.sock. Find it with: stat -c '%g' /var/run/docker.sock
TALOS_DOCKER_GID=999
