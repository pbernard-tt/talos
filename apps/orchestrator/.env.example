# Internal API root
TALOS_API_BASE_URL=http://talos-api:8080

# Service auth (same value as talos-api's TALOS_INTERNAL_API_TOKEN)
TALOS_INTERNAL_API_TOKEN=change-me-to-a-random-64-char-token

# Transport + locks
TALOS_RABBITMQ_URL=amqp://talos:talos@rabbitmq:5672
TALOS_REDIS_URL=redis://redis:6379

# Runner HTTP root
TALOS_RUNNER_BASE_URL=http://talos-runner-supervisor:8081

# Concurrency cap
TALOS_MAX_ACTIVE_RUNS=1

# Overall run timeout, minutes
TALOS_RUN_TIMEOUT_MINUTES=60

# Phase 11: per-run container image, resolved from project.stackType
TALOS_WORKER_IMAGE_BASE=workers/base-agent-runner:latest
TALOS_WORKER_IMAGE_JAVA=workers/java-runner:latest
TALOS_WORKER_IMAGE_NODE=workers/node-runner:latest
TALOS_WORKER_IMAGE_PYTHON=workers/python-runner:latest

# Phase 11: periodic workspace retention sweep
TALOS_RETENTION_MAX_AGE_DAYS=7
TALOS_RETENTION_INTERVAL_SECONDS=21600
