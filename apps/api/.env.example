# PostgreSQL JDBC URL
TALOS_DB_URL=jdbc:postgresql://postgres:5432/talos
# Database credentials
TALOS_DB_USER=talos
TALOS_DB_PASSWORD=talos

# Queue connection
TALOS_RABBITMQ_URL=amqp://talos:talos@rabbitmq:5672

# Locks + log pub/sub
TALOS_REDIS_URL=redis://redis:6379

# JWT signing key (64+ random chars)
TALOS_JWT_SECRET=change-me-to-a-random-64-char-secret

# Shared service token for /internal/v1, used by orchestrator + runner supervisor (64+ random chars)
TALOS_INTERNAL_API_TOKEN=change-me-to-a-random-64-char-token

# Seeded admin (password rotated after first login)
TALOS_ADMIN_EMAIL=admin@example.com
TALOS_ADMIN_PASSWORD=change-me

# AES-256-GCM key for secret_values (32-byte base64)
TALOS_SECRETS_KEY=change-me-32-byte-base64-key

# HMAC verification for /webhooks/github
TALOS_GITHUB_WEBHOOK_SECRET=change-me

# Phase 11: login rate limiter (attempts allowed per client IP per window before 429)
TALOS_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
TALOS_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# Comma-separated browser origins allowed to call this API (talos-web runs on a different
# origin -- unset means no origins are allowed, so the SPA's login will fail CORS preflight)
TALOS_CORS_ALLOWED_ORIGINS=http://localhost:4200
