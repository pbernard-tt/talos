# Webhook verification handshake token (you choose this; must match the value entered in the
# Meta developer console when subscribing the webhook)
TALOS_WHATSAPP_VERIFY_TOKEN=change-me

# WhatsApp Cloud API app secret, used to verify the X-Hub-Signature-256 on inbound webhooks
TALOS_WHATSAPP_APP_SECRET=change-me

# WhatsApp Cloud API access token + phone number id (from the Meta developer console)
TALOS_WHATSAPP_ACCESS_TOKEN=change-me
TALOS_WHATSAPP_PHONE_NUMBER_ID=change-me

# Comma-separated WhatsApp sender IDs allowed to trigger runs; anything else is rejected and audited
TALOS_WHATSAPP_ALLOWED_IDS=change-me-to-a-comma-separated-list-of-wa-ids

# Internal API root
TALOS_API_BASE_URL=http://talos-api:8080

# Seeded chat trigger service account (must match talos-api's TALOS_WHATSAPP_SERVICE_EMAIL/PASSWORD)
TALOS_WHATSAPP_SERVICE_EMAIL=whatsapp-bot@talos.local
TALOS_WHATSAPP_SERVICE_PASSWORD=change-me

# Deep links back into the dashboard (e.g. "view the run")
TALOS_WEB_BASE_URL=http://localhost:4200

# Transport + locks
TALOS_RABBITMQ_URL=amqp://talos:talos@rabbitmq:5672
TALOS_REDIS_URL=redis://redis:6379

# WhatsApp Cloud Graph API base URL (override only for testing against a different API version)
TALOS_WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com/v20.0
