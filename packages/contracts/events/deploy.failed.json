{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://talos.dev/schemas/events/deploy.failed.json",
  "title": "deploy.failed",
  "description": "Section 11: API -> notifiers, published either when DeployService.triggerNow's own call to Dokploy fails synchronously, or by DeployStatusPoller when a deployment reaches the terminal 'error' state (Phase 10).",
  "type": "object",
  "required": ["event_id", "event_type", "occurred_at", "version", "payload"],
  "additionalProperties": false,
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "deploy.failed" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "version": { "const": 1 },
    "payload": {
      "type": "object",
      "required": ["run_id", "project_id", "environment", "dokploy_app_id"],
      "additionalProperties": false,
      "properties": {
        "run_id": { "type": "string", "format": "uuid" },
        "project_id": { "type": "string", "format": "uuid" },
        "environment": { "type": "string" },
        "dokploy_app_id": { "type": "string" },
        "error": { "type": ["string", "null"] }
      }
    }
  }
}
