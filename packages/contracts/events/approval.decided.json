{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://talos.dev/schemas/events/approval.decided.json",
  "title": "approval.decided",
  "description": "Section 11: API -> orchestrator (talos.orchestrator.approvals), published on a human approve/reject/request-changes decision (Phase 8). Not yet consumed -- the orchestrator only acts on it from Phase 9 (push/PR after approval).",
  "type": "object",
  "required": ["event_id", "event_type", "occurred_at", "version", "payload"],
  "additionalProperties": false,
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "approval.decided" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "version": { "const": 1 },
    "payload": {
      "type": "object",
      "required": ["approval_id", "run_id", "status", "decided_by"],
      "additionalProperties": false,
      "properties": {
        "approval_id": { "type": "string", "format": "uuid" },
        "run_id": { "type": "string", "format": "uuid" },
        "status": { "type": "string", "enum": ["APPROVED", "REJECTED", "CHANGES_REQUESTED"] },
        "decided_by": { "type": ["string", "null"], "format": "uuid" }
      }
    }
  }
}
